<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8"/>
        <meta http-equiv="x-ua-compatible" content="ie=edge"/>
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
        <title>{{ post.title|lower }} {%if post %}|{% endif %} jack marchant</title>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
        <link href="/prism.css" rel="stylesheet" type="text/css" />
        <link href="/style.css" rel="stylesheet" type="text/css" />
        <meta name="description" content="I'm a Software Engineer from Sydney. I like writing code and talking about it." />
        <meta property="og:title" content="Software Engineer" />
        <meta property="og:description" content="I'm a Software Engineer from Sydney. I like writing code and talking about it." />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    </head>
    <body>
        <header class="site-header">
            <div class="container">
                <div class="site-header__row">
                    <p class="site-prompt">jackmarchant@blog:~$</p>
                    <button class="subscribe-btn" type="button" data-subscribe-btn>subscribe</button>
                </div>
                <h1 class="site-title"><a href="/">jack marchant</a></h1>
                <p class="site-tagline">principal engineer @ <a target="_blank" rel="noopener noreferrer" href="https://deputy.com">deputy</a> · writing about software</p>
            </div>
        </header>

        <div class="subscribe-modal" data-subscribe-modal aria-hidden="true">
            <div class="subscribe-modal__backdrop" data-subscribe-backdrop></div>
            <div class="subscribe-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="subscribe-modal-title">
                <div class="subscribe-modal__header">
                    <h2 class="subscribe-modal__title" id="subscribe-modal-title">subscribe</h2>
                    <button class="subscribe-modal__close" type="button" data-subscribe-close aria-label="close">×</button>
                </div>
                <p class="subscribe-modal__desc">get new posts delivered to your inbox</p>
                <form class="subscribe-form" action="https://jackmarchant.us1.list-manage.com/subscribe/post?u=5a51a355f4187fddb0d0f4816&amp;id=a740cde517c" method="post" target="_blank" rel="noopener noreferrer" novalidate>
                    <div style="position:absolute;left:-5000px;" aria-hidden="true">
                        <input type="text" name="b_5a51a355f4187fddb0d0f4816_a740cde517c" tabindex="-1" value="" />
                    </div>
                    <input type="email" name="EMAIL" class="subscribe-form__input" placeholder="your@email.com" required />
                    <button type="submit" class="subscribe-form__submit">subscribe →</button>
                </form>
            </div>
        </div>
        <main class="container">
            {% if posts %}
                <section class="post-directory" data-post-directory>
                    <div class="tag-filter-bar" data-tag-filter-bar>
                        <button class="tag-filter-btn is-active" data-tag-filter="all">all</button>
                        {% for tag in tags %}
                            <button class="tag-filter-btn tag-filter-btn--{{ tag|lower|replace({' ': '-'}) }}" data-tag-filter="{{ tag|lower }}">{{ tag }}</button>
                        {% endfor %}
                    </div>
                    <p class="post-count">— <span data-results-count>{{ posts|length }}</span> posts —</p>
                    <div class="post-list" data-post-list>
                        {% for listing in posts %}
                            <article class="post-card" data-post-card data-title="{{ listing.title|lower|e('html_attr') }}" data-tags="{{ listing.tags|join(' ')|lower|e('html_attr') }}">
                                <button class="post-card__toggle" type="button" data-expand-toggle aria-expanded="false">
                                    <span class="post-card__title">{{ listing.title|lower }}</span>
                                    <span class="post-card__date">{{ listing.date }}</span>
                                </button>
                                <div class="post-card__tags">
                                    {% for tag in listing.tags %}
                                        <span class="tag-chip tag-chip--{{ tag|lower|replace({' ': '-'}) }}">{{ tag }}</span>
                                    {% endfor %}
                                </div>
                                <div class="post-card__excerpt" data-expandable>
                                    <div class="post-card__excerpt-content">
                                        {{ listing.blurb | raw }}
                                        <a href="{{ listing.url }}" class="post-card__read-more">read full post →</a>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if post %}
                <div class="reading-progress" data-reading-progress aria-hidden="true">
                    <div class="reading-progress__bar" data-reading-progress-bar></div>
                </div>
                <article class="post" data-post>
                    <h2 class="post__title">{{ post.title|lower }}</h2>
                    <p class="post__date">{{ post.date }}</p>
                    {{ post.content|raw }}
                </article>
            {% endif %}
        </main>

        <script src="/prism.js"></script>
        <script src="/index.js"></script>

        {% if settings.environment == 'production' %}
            <!-- Google tag (gtag.js) -->
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-8T5L82C44Y"></script>
            <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());

            gtag('config', 'G-8T5L82C44Y');
            </script>
        {% endif %}
    </body>
</html>
