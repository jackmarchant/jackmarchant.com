<!DOCTYPE html>
<html data-theme="dark">
    <head>
        <meta charset="utf-8"/>
        <meta http-equiv="x-ua-compatible" content="ie=edge"/>
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no"/>
        <title>{% if post %}{{ post.title|lower }} | {% endif %}jack marchant</title>
        <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
        <link href="/prism.css" rel="stylesheet" type="text/css" />
        <link href="/style.css" rel="stylesheet" type="text/css" />
        {% if post %}
        <meta name="description" content="{{ post.blurb|e }}" />
        <meta property="og:type" content="article" />
        <meta property="og:title" content="{{ post.title|e }}" />
        <meta property="og:description" content="{{ post.blurb|e }}" />
        <meta property="og:url" content="https://www.jackmarchant.com{{ post.url }}" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content="{{ post.title|e }}" />
        <meta name="twitter:description" content="{{ post.blurb|e }}" />
        {% else %}
        <meta name="description" content="I'm a Software Engineer from Sydney. I like writing code and talking about it." />
        <meta property="og:type" content="website" />
        <meta property="og:title" content="Jack Marchant — Software Engineer" />
        <meta property="og:description" content="I'm a Software Engineer from Sydney. I like writing code and talking about it." />
        <meta property="og:url" content="https://www.jackmarchant.com" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content="Jack Marchant — Software Engineer" />
        <meta name="twitter:description" content="I'm a Software Engineer from Sydney. I like writing code and talking about it." />
        {% endif %}
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <script>(function(){try{var t=localStorage.getItem('theme')||'dark';document.documentElement.setAttribute('data-theme',t);}catch(e){}}());</script>
    </head>
    <body>
        <header class="site-header">
            <div class="container">
                <div class="site-header__row">
                    <p class="site-prompt">jackmarchant@blog:~$</p>
                    <div class="site-header__actions">
                        <button class="theme-toggle" type="button" data-theme-toggle aria-label="switch to light mode">
                            <svg class="theme-toggle__sun" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
                            <svg class="theme-toggle__moon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
                        </button>
                        <button class="subscribe-btn" type="button" data-subscribe-btn>subscribe</button>
                    </div>
                </div>
                <h1 class="site-title"><a href="/">jack marchant</a></h1>
                <p class="site-tagline">principal engineer @ <a target="_blank" rel="noopener noreferrer" href="https://deputy.com">deputy</a> · writing about software</p>
            </div>
        </header>

        <div class="subscribe-modal" data-subscribe-modal aria-hidden="true">
            <div class="subscribe-modal__backdrop" data-subscribe-backdrop></div>
            <div class="subscribe-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="subscribe-modal-title">
                <div class="subscribe-modal__header">
                    <h2 class="subscribe-modal__title" id="subscribe-modal-title">subscribe</h2>
                    <button class="subscribe-modal__close" type="button" data-subscribe-close aria-label="close">×</button>
                </div>
                <p class="subscribe-modal__desc">get new posts delivered to your inbox</p>
                <form class="subscribe-form" action="https://jackmarchant.us14.list-manage.com/subscribe?u=5a51a355f4187fddb0d0f4816&amp;id=b5ae7106ea" method="POST" target="_blank" rel="noopener noreferrer" novalidate>
                    <div style="position:absolute;left:-5000px;" aria-hidden="true">
                        <input type="text" name="b_5a51a355f4187fddb0d0f4816_a740cde517" tabindex="-1" value="" />
                    </div>
                    <input type="email" name="EMAIL" id="mce-EMAIL" class="subscribe-form__input" placeholder="your@email.com" required />
                    <button type="submit" class="subscribe-form__submit">subscribe →</button>
                </form>
            </div>
        </div>
        <main class="container">
            {% if posts %}
                <section class="post-directory" data-post-directory>
                    <div class="tag-filter-bar" data-tag-filter-bar>
                        <button class="tag-filter-btn is-active" data-tag-filter="all">all</button>
                        {% for tag in tags %}
                            <button class="tag-filter-btn tag-filter-btn--{{ tag|lower|replace({' ': '-'}) }}" data-tag-filter="{{ tag|lower }}">{{ tag }}</button>
                        {% endfor %}
                    </div>
                    <p class="post-count">— <span data-results-count>{{ posts|length }}</span> posts —</p>
                    <div class="post-list" data-post-list>
                        {% for listing in posts %}
                            <article class="post-card" data-post-card data-title="{{ listing.title|lower|e('html_attr') }}" data-tags="{{ listing.tags|join(' ')|lower|e('html_attr') }}">
                                <button class="post-card__toggle" type="button" data-expand-toggle aria-expanded="false">
                                    <span class="post-card__title">{{ listing.title|lower }}</span>
                                    <span class="post-card__date">{{ listing.date }}</span>
                                </button>
                                <div class="post-card__tags">
                                    {% for tag in listing.tags %}
                                        <span class="tag-chip tag-chip--{{ tag|lower|replace({' ': '-'}) }}">{{ tag }}</span>
                                    {% endfor %}
                                </div>
                                <div class="post-card__excerpt" data-expandable>
                                    <div class="post-card__excerpt-content">
                                        {{ listing.blurb | raw }}
                                        <a href="{{ listing.url }}" class="post-card__read-more">read full post →</a>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    </div>
                </section>
            {% endif %}

            {% if post %}
                <div class="reading-progress" data-reading-progress aria-hidden="true">
                    <div class="reading-progress__bar" data-reading-progress-bar></div>
                </div>
                <article class="post" data-post>
                    <h2 class="post__title">{{ post.title|lower }}</h2>
                    <p class="post__date">{{ post.date }}</p>
                    {% if post.tldr %}
                    <div class="post__tldr">
                        <span class="post__tldr-label">tl;dr</span>
                        <p class="post__tldr-text">{{ post.tldr }}</p>
                    </div>
                    {% endif %}
                    {{ post.content|raw }}
                </article>
            {% endif %}
        </main>

        <script src="/prism.js"></script>
        <script src="/index.js"></script>

        {% if settings.environment == 'production' %}
            <!-- Google tag (gtag.js) -->
            <script async src="https://www.googletagmanager.com/gtag/js?id=G-8T5L82C44Y"></script>
            <script>
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            gtag('js', new Date());

            gtag('config', 'G-8T5L82C44Y');
            </script>
        {% endif %}
    </body>
</html>
